{% set role_suffix = ': ' %}
{% set turn_suffix = '\n' %}

{% for message in messages %}
    {% if message['role'].upper() == 'ASSISTANT' %}
        {%- if message['content'] is string -%}
            {{ message['role'].upper() + role_suffix }}{% generation %}{{message['content'] | trim}}{% endgeneration %}{% if not loop.last %}{{ turn_suffix }}{% endif %}
        {%- else -%}
            {{ message['role'].upper() + role_suffix }}{% generation %}{%- for item in message['content'] -%}{%- if item['type'] == 'text' -%}{{ item['text'] | trim }}{%- endif -%}{%- endfor -%}{% endgeneration %}{% if not loop.last %}{{ turn_suffix }}{% endif %}
        {%- endif -%}
    {% else %}
        {%- if message['content'] is string -%}
            {{ message['role'].upper() + role_suffix + message['content'] | trim }}{% if not loop.last %}{{ turn_suffix }}{% endif %}
        {%- else -%}
            {{ message['role'].upper() + role_suffix }}{%- for item in message['content'] -%}{%- if item['type'] == 'text' -%}{{ item['text'] | trim }}{%- endif -%}{%- endfor -%}{% if not loop.last %}{{ turn_suffix }}{% endif %}
        {%- endif -%}
    {% endif %}
{% endfor %}
{% if add_generation_prompt %}
    {{ turn_suffix + "ASSISTANT" + role_suffix }}
{% endif %}
