{# Gemma 2 Instruct chat template with system message support #}
{# System messages are prepended to the first user message #}

{%- if messages[0]['role'] == 'system' -%}
    {%- if messages[0]['content'] is string -%}
        {%- set system_message = messages[0]['content'] -%}
    {%- else -%}
        {%- set system_message = messages[0]['content'][0]['text'] -%}
    {%- endif -%}
    {%- set messages = messages[1:] -%}
{%- else -%}
    {%- set system_message = '' -%}
{%- endif -%}

{{ bos_token }}
{%- for message in messages -%}
    {%- if (message['role'] == 'user') != (loop.index0 % 2 == 0) -%}
        {{ raise_exception('Conversation roles must alternate user/assistant/user/assistant/...') }}
    {%- endif -%}

    {%- if message['role'] == 'assistant' -%}
        {%- set role = 'model' -%}
    {%- else -%}
        {%- set role = message['role'] -%}
    {%- endif -%}

    {%- if message['content'] is string -%}
        {%- set msg_text = message['content'] | trim -%}
    {%- else -%}
        {%- set ns = namespace(text='') -%}
        {%- for item in message['content'] -%}
            {%- if item['type'] == 'text' -%}
                {%- set ns.text = ns.text + item['text'] -%}
            {%- endif -%}
        {%- endfor -%}
        {%- set msg_text = ns.text | trim -%}
    {%- endif -%}

    {%- if loop.first and system_message -%}
        {{ '<start_of_turn>' + role + '\n' + system_message + '\n\n' + msg_text + '<end_of_turn>\n' }}
    {%- else -%}
        {{ '<start_of_turn>' + role + '\n' + msg_text + '<end_of_turn>\n' }}
    {%- endif -%}
{%- endfor -%}

{%- if add_generation_prompt -%}
    {{ '<start_of_turn>model\n' }}
{%- endif -%}
